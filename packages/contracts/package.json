{
  "name": "@attesta/contracts",
  "version": "0.1.0",
  "description": "ATTESTA smart contracts — DID, ZK verifiers, TrustChain escrow, DAO governance",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "deploy:local": "hardhat run scripts/deploy-all.ts --network localhost",
    "deploy:amoy": "hardhat run scripts/deploy-all.ts --network amoy",
    "deploy:polygon": "hardhat run scripts/deploy-all.ts --network polygon",
    "circuits:build": "bash scripts/build-circuits.sh",
    "transfer-ownership": "hardhat run scripts/transfer-ownership.ts --network polygon",
    "node": "hardhat node",
    "typecheck": "tsc --noEmit",
    "size": "hardhat size-contracts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@types/node": "^20.14.0",
    "hardhat": "^2.22.5",
    "hardhat-contract-sizer": "^2.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "ethers": "^6.13.1"
  }
}
