  },
  "keywords": ["openrep", "did", "verifiable-credentials", "professional-trust", "attesta", "polygon"],
  "repository": { "type": "git", "url": "https://github.com/attesta-io/openrep" },
  "homepage": "https://openrep.io",
  "dependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
