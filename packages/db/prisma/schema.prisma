// ATTESTA — Main Database Schema
// PostgreSQL 16 via Prisma 5.x
//
// Verification Tiers (highest → lowest trust):
//   T1 Government  10/10  Onfido ZK government ID (Phase 3)
//   T2 Employer     9/10  Employer co-signed on Polygon (Phase 5)
//   T3 Institution  8/10  University / institution (Phase 12)
//   T4 Peer         6/10  Peer co-attested (Phase 6)
//   T5 AI Inferred  5/10  AI evaluation score (Phase 6)
//   T6 Self         1/10  Self-reported — default for new users (Phase 1)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum VerificationTier {
  T1_GOVERNMENT
  T2_EMPLOYER
  T3_INSTITUTION
  T4_PEER
  T5_AI_INFERRED
  T6_SELF // Default for new users
}

// Auth providers — keep in sync with @attesta/shared AuthProvider enum
enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
  SIWE // Sign-In With Ethereum
}

// ─────────────────────────────────────────────────────────────
// Core Identity
// ─────────────────────────────────────────────────────────────

// Central user record.
// Each user maps to one W3C Decentralized Identifier (DID).
// PII (email) encrypted at rest in production via AWS KMS.
model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Email — encrypted in production (stored as KMS-tokenized ciphertext)
  email         String?   @unique
  emailVerified DateTime?

  // Blockchain identity — created by Privy.io on first sign-up
  did            String? @unique // e.g. "did:polygon:0xabc123..."
  polygonAddress String? @unique // EVM wallet address from Privy

  // Verification level — increases as user adds proof
  kycTier   VerificationTier @default(T6_SELF)
  kycStatus String?          @default("NONE") // NONE | PENDING | APPROVED | REJECTED

  // Phase 3 — FaceTec 3D liveness (ISO 30107-3, Step 1 of KYC)
  facetecSessionId  String?   // FaceTec session ID after successful liveness check
  facetecVerifiedAt DateTime? // Timestamp of liveness pass — gates Onfido doc check

  // Phase 3 — Veriff government ID verification (Step 2 of KYC — document + selfie)
  veriffSessionId   String? // Veriff session ID, used to reconcile webhook decisions

  // Phase 9 — Stripe Connect (candidate payouts)
  stripeAccountId String? // Stripe Connect express account ID (acct_...)

  // GDPR consent preferences (Article 7 — explicit consent)
  consentAnalytics  Boolean @default(false)
  consentMarketing  Boolean @default(false)
  consentAiTraining Boolean @default(false)
  consentUpdatedAt  DateTime?

  // Display info
  name     String?
  imageUrl String?

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  refreshTokens RefreshToken[]
  employerAdmin       Employer[]           @relation("EmployerAdmin")
  employmentRecords   EmploymentRecord[]   @relation("CandidateEmploymentRecords")
  skillAttestations   SkillAttestation[]   @relation("UserSkillAttestations")
  trialsAsCandidate   Trial[]              @relation("CandidateTrials")
  fitScores           StoredFitScore[]     @relation("CandidateFitScores")
  referralsSent       Referral[]           @relation("ReferrerReferrals")
  referralsReceived   Referral[]           @relation("CandidateReferrals")
  trustEdgesFrom      TrustEdge[]          @relation("TrustEdgeFrom")
  trustEdgesTo        TrustEdge[]          @relation("TrustEdgeTo")

  @@map("users")
}

// OAuth and SIWE authentication accounts.
// One user can have multiple accounts (e.g. email + GitHub + SIWE wallet).
model Account {
  id     String @id @default(cuid())
  userId String

  type              String       // "oauth" | "credentials" | "siwe"
  provider          AuthProvider
  providerAccountId String // OAuth "sub" OR wallet address for SIWE

  // OAuth tokens (encrypted at rest in production)
  accessToken  String? @db.Text
  refreshToken String? @db.Text
  expiresAt    Int?
  tokenType    String?
  scope        String?
  idToken      String? @db.Text
  sessionState String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// Auth.js browser sessions (stored in DB for server-side invalidation).
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// Email magic-link / OTP tokens (used by Resend provider in Auth.js).
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────
// API JWT Refresh Tokens
// ─────────────────────────────────────────────────────────────

// Tracks API refresh tokens for audit + revocation.
// Actual token value lives in Redis (fast invalidation).
// This table is the source of truth for revocation status.
model RefreshToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  expiresAt DateTime

  userId String

  // SHA-256 hash of the raw token — never store raw tokens in DB
  tokenHash String @unique

  // Soft revocation — checked before any refresh attempt
  revokedAt     DateTime?
  revokedReason String? // "logout" | "rotated" | "suspicious"

  // Audit trail
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// Employer System (Phase 4)
// ─────────────────────────────────────────────────────────────

enum EmployerBillingPlan {
  PER_HIRE        // $99/hire — pay-as-you-go
  SUBSCRIPTION    // $2,000/month flat
}

enum EmployerStatus {
  PENDING         // registered, domain not yet verified
  ACTIVE          // domain verified, billing active
  SUSPENDED       // billing lapsed or policy violation
}

// Legal entity that uses ATTESTA to hire.
// One admin User owns the Employer; additional members can be added (Phase 4+).
model Employer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Company identity
  name        String
  domain      String  @unique // e.g. "acme.com" — verified via DNS TXT record
  logoUrl     String?
  website     String?
  industry    String?
  size        String? // "1-10" | "11-50" | "51-200" | "201-500" | "500+"

  // Admin user — the person who registered the employer account
  adminUserId String
  adminUser   User    @relation("EmployerAdmin", fields: [adminUserId], references: [id])

  // Status
  status EmployerStatus @default(PENDING)

  // Domain verification
  domainVerifications EmployerDomainVerification[]

  // Stripe billing
  stripeCustomerId     String? @unique
  stripePlan           EmployerBillingPlan @default(PER_HIRE)
  stripeSubscriptionId String? @unique // set when on SUBSCRIPTION plan
  billingEmail         String?
  trialEndsAt          DateTime? // 14-day trial for new employers

  // Usage tracking (for PER_HIRE plan invoicing)
  totalHires   Int @default(0)
  currentMonth Int @default(0) // hire count in current billing month

  // HRIS integration (Phase 4+ — Workday / BambooHR webhook)
  hrisConnected Boolean @default(false)
  hrisProvider  String? // "workday" | "bamboohr"
  hrisSecret    String? // HMAC shared secret for webhook signature verification (encrypted at rest)

  employmentRecords EmploymentRecord[] @relation("EmployerEmploymentRecords")

  @@index([adminUserId])
  @@map("employers")
}

// DNS TXT record domain verification challenge.
// We generate a unique token; employer adds it as a TXT record on their domain;
// we poll/verify via DNS lookup. One attempt per verification cycle.
model EmployerDomainVerification {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  verifiedAt DateTime?

  employerId String
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)

  domain String // mirrors Employer.domain at time of verification
  token  String @unique // "attesta-verify=<random32hex>" — placed in TXT record

  // Status of this verification attempt
  verified Boolean @default(false)
  attempts Int     @default(0) // number of DNS poll attempts made
  lastAttemptAt DateTime?

  @@index([employerId])
  @@map("employer_domain_verifications")
}

// ─────────────────────────────────────────────────────────────
// ProofWork Profile (Phase 2 — scaffolded here for Phase 1 FK)
// ─────────────────────────────────────────────────────────────

// Public-facing ProofWork profile — the candidate's verifiable resume.
// Shareable at attesta.io/proof/{did}
model Profile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core fields
  headline String? // e.g. "Senior Full-Stack Engineer"
  bio      String? @db.Text
  location String?
  timezone String? // IANA timezone, e.g. "America/New_York"

  // Social links
  websiteUrl     String?
  githubUsername String?
  linkedinUrl    String?

  // ATTESTA metrics
  completenessScore Int     @default(0) // 0-100, shown during onboarding wizard
  overallTrustScore Decimal @default(0) @db.Decimal(5, 2) // Weighted avg of attestations

  // Phase 3 — DID anchoring
  did          String? // mirrors User.did, denormalised for profile queries
  chainTxHash  String? // Polygon tx hash of the DID anchor transaction

  // IPFS snapshot for OpenRep portability (Phase 8)
  ipfsCid       String?
  ipfsUpdatedAt DateTime?

  // Privacy
  isPublic     Boolean @default(true) // Show in RoleFit search
  isSearchable Boolean @default(true) // Include in AI matching

  @@map("profiles")
}

// ─────────────────────────────────────────────────────
// Phase 5 — Employment Co-Sign
// ─────────────────────────────────────────────────────

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

// State machine: PENDING_EMPLOYER → SIGNED → ANCHORING → ANCHORED
//                                          ↘ REJECTED
//                PENDING_EMPLOYER → CANCELLED
enum EmploymentRecordStatus {
  PENDING_EMPLOYER // Candidate submitted; awaiting employer countersign
  SIGNED           // Both parties signed; queued for Polygon anchor
  ANCHORING        // BullMQ worker submitted the tx; waiting for confirmation
  ANCHORED         // Tx confirmed; T2_EMPLOYER tier applied to candidate
  REJECTED         // Employer explicitly rejected the record
  CANCELLED        // Candidate cancelled before employer signed
}

// EmploymentRecord — co-signed employment attestation.
// Employer receives a one-time email token and never needs an ATTESTA account.
// After both parties sign, an async worker pins the doc to IPFS and updates
// the candidate's DID on Polygon with T2_EMPLOYER tier.
model EmploymentRecord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidateId String
  candidate   User     @relation("CandidateEmploymentRecords", fields: [candidateId], references: [id], onDelete: Cascade)

  employerId String
  employer   Employer @relation("EmployerEmploymentRecords", fields: [employerId], references: [id], onDelete: Restrict)

  jobTitle       String
  department     String?
  startDate      DateTime
  endDate        DateTime? // null = currently employed
  employmentType EmploymentType @default(FULL_TIME)

  // SHA-256 of the canonical JSON document — both parties implicitly sign this
  documentHash String?

  // Signature timestamps (the actual private-key sig is the countersign token delivery)
  candidateSignedAt DateTime?
  employerSignedAt  DateTime?

  // Storage references — set after anchor job completes
  ipfsCid         String?   // Pinata CID of the co-signed JSON document
  chainTxHash     String?   // Polygon tx hash from DIDRegistry.update()
  chainAnchoredAt DateTime? // Block timestamp of the anchor tx

  status EmploymentRecordStatus @default(PENDING_EMPLOYER)

  // One-time 32-byte hex token emailed to the employer.
  // Nulled out after use (sign or reject) — cannot be replayed.
  countersignToken          String?   @unique
  countersignTokenExpiresAt DateTime?

  @@index([candidateId])
  @@index([employerId])
  @@index([status])
  @@map("employment_records")
}

// ─────────────────────────────────────────────────────────────
// Phase 6 — Skills + AI Eval
// ─────────────────────────────────────────────────────────────

enum SkillArtifactType {
  GITHUB_REPO // Full GitHub repo URL
  GIST        // GitHub Gist URL
  URL         // Any public URL (blog, demo, deployed project)
  TEXT        // Inline description / paste
}

// State machine: PENDING → EVALUATING → SCORED → ANCHORING → ANCHORED
//                       ↘ FAILED (eval or anchor error)
enum SkillAttestationStatus {
  PENDING     // Submitted, queued for AI eval
  EVALUATING  // AI model currently scoring
  SCORED      // AI score available; ready to anchor
  ANCHORING   // Blockchain tx submitted; awaiting confirmation
  ANCHORED    // On-chain; badge visible on profile
  FAILED      // Non-retryable error
}

enum SkillEvalJobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

// SkillAttestation — AI-evaluated evidence of a skill.
// Candidate submits an artifact; CodeLlama/CLIP/Llama3.1 scores it;
// after scoring the anchor worker writes the result to Polygon.
model SkillAttestation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User   @relation("UserSkillAttestations", fields: [userId], references: [id], onDelete: Cascade)

  // Skill identity
  skillSlug  String // e.g. "typescript", "react", "python", "system-design"
  skillLevel Int?   // 1–10, set by AI after evaluation

  // Artifact submitted for evaluation
  artifactUrl  String?           // original URL
  artifactType SkillArtifactType @default(URL)

  // IPFS snapshot of the artifact metadata
  evidenceCid String? // Pinata IPFS CID

  // AI evaluation results (set by skill-eval worker)
  aiEvalScore    Decimal? @db.Decimal(5, 2) // 0–100 overall score
  aiEvalReport   Json?    // full breakdown: categories, reasoning, code_quality, etc.
  plagiarismScore Decimal? @db.Decimal(4, 3) // 0.0–1.0; >0.8 = likely plagiarised

  // On-chain anchor (set by skill-anchor worker)
  chainTxHash     String?
  chainAnchoredAt DateTime?

  status SkillAttestationStatus @default(PENDING)

  // Peer co-attestation (Phase 6)
  evidenceType  String  @default("SELF")  // "SELF" | "PEER" | "AI"
  peerCoSigned  Boolean @default(false)

  evalJob              SkillEvalJob?
  peerAttestationReqs  PeerAttestationRequest[]

  @@index([userId])
  @@index([skillSlug])
  @@index([status])
  @@map("skill_attestations")
}

// PeerAttestationRequest — one-time token sent to a co-worker for peer co-signing.
model PeerAttestationRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  attestationId String
  attestation   SkillAttestation @relation(fields: [attestationId], references: [id], onDelete: Cascade)

  peerEmail    String
  relationship String // e.g. "colleague", "manager", "report"
  token        String   @unique
  expiresAt    DateTime

  verdict  String?  // "CONFIRM" | "DECLINE" — set when peer responds
  comment  String?  @db.Text
  usedAt   DateTime?

  @@index([attestationId])
  @@index([token])
  @@map("peer_attestation_requests")
}

// SkillEvalJob — tracks the async AI evaluation job for an attestation.
model SkillEvalJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attestationId String           @unique
  attestation   SkillAttestation @relation(fields: [attestationId], references: [id], onDelete: Cascade)

  queueJobId String? // BullMQ job ID
  attempts   Int     @default(0)
  lastError  String? @db.Text

  startedAt   DateTime?
  completedAt DateTime?

  status SkillEvalJobStatus @default(QUEUED)

  @@index([attestationId])
  @@map("skill_eval_jobs")
}

// ─────────────────────────────────────────────────────────────
// Phase 7 — ZK Disclosure
// ─────────────────────────────────────────────────────────────

enum ZKClaimType {
  SALARY_RANGE         // Prove salary ∈ [min, max] (SalaryRangeVerifier.sol)
  EMPLOYMENT_DURATION  // Prove tenure >= minMonths (EmploymentVerifier.sol)
}

// State machine: PENDING_PROOF → PROOF_SUBMITTED → VERIFIED
//                             ↘ DECLINED (candidate refused)
//                PENDING_PROOF → EXPIRED (7 days no response)
enum ZKDisclosureStatus {
  PENDING_PROOF    // Employer requested; waiting for candidate to generate proof
  PROOF_SUBMITTED  // Candidate generated proof; API verifying on-chain
  VERIFIED         // On-chain verifyProof() returned true ✓
  DECLINED         // Candidate explicitly declined the request
  EXPIRED          // Request expired without response
  FAILED           // On-chain verification returned false
}

// ZKDisclosureRequest — employer asks candidate to prove a claim via ZK.
// Private inputs (actual salary, tenure) NEVER leave the candidate's browser.
// Only the Groth16 proof + public signals travel over the network.
model ZKDisclosureRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime // 7 days from creation

  // Parties
  requesterId String // employer user ID who sent the request
  candidateId String // candidate who must prove the claim

  // Claim being requested
  claimType   ZKClaimType
  // SALARY_RANGE:        { "minSalary": 150000, "maxSalary": 250000 }  (USD, whole dollars)
  // EMPLOYMENT_DURATION: { "minMonths": 12 }
  claimParams Json

  // Proof submitted by candidate (set after candidate runs SnarkJS in browser)
  proof        Json?    // { pi_a: [x,y], pi_b: [[x,y],[x,y]], pi_c: [x,y], publicSignals: [...] }
  proofTxHash  String?  // Polygon tx hash of the on-chain verifyProof() call
  proofResult  Boolean? // result of on-chain verification

  status ZKDisclosureStatus @default(PENDING_PROOF)

  @@index([candidateId])
  @@index([requesterId])
  @@index([status])
  @@map("zk_disclosure_requests")
}

// ─── Phase 9: WorkProof Live ──────────────────────────────────────────────────

enum TrialDomain {
  CODE
  DESIGN
  WRITING
  DATA
}

enum TrialStatus {
  DRAFT
  INVITED
  LEGAL_PENDING   // WPTA sent, awaiting candidate signature
  READY           // signed, sandbox not yet launched
  IN_PROGRESS     // sandbox live
  SUBMITTED       // candidate submitted work
  EVALUATING      // AI eval job running
  SCORED          // scores recorded
  CANCELLED
  EXPIRED
}

enum TrialScoreDimension {
  CAPABILITY
  QUALITY
  SPEED
  COMMUNICATION
  CULTURE
}

// Trial — one paid real-work session between employer and candidate.
model Trial {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employerId  String
  candidateId String
  candidate   User   @relation("CandidateTrials", fields: [candidateId], references: [id], onDelete: Cascade)

  domain          TrialDomain @default(CODE)
  roleTitle       String
  briefMarkdown   String?     @db.Text
  durationMinutes Int         @default(120)

  compensationCandidateUsd Int @default(100)
  compensationEmployerUsd  Int @default(300)

  status      TrialStatus @default(DRAFT)
  invitedAt   DateTime?
  startedAt   DateTime?
  submittedAt DateTime?
  expiresAt   DateTime?

  sandboxContainerId String?
  sandboxSessionUrl  String?
  recordingS3Key     String? // AES-256 encrypted at rest

  // Anti-cheat signals
  keystrokeEntropyScore Decimal? @db.Decimal(5, 3)
  pasteEventCount       Int      @default(0)
  antiCheatFlags        Json?

  // Stripe payouts
  stripePaymentIntentId      String?
  stripeCandidateTransferId  String?
  candidatePayoutAmountUsd   Decimal? @db.Decimal(8, 2) // $50–$200
  candidatePaidAt            DateTime?

  scores TrialScore[]
  legal  TrialLegal?

  @@index([candidateId])
  @@index([employerId])
  @@index([status])
  @@map("trials")
}

// TrialScore — one row per dimension (5 total when complete).
model TrialScore {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  trialId   String
  trial     Trial  @relation(fields: [trialId], references: [id], onDelete: Cascade)

  dimension  TrialScoreDimension
  score      Int               // 0-100
  percentile Decimal?          @db.Decimal(5, 2)
  reasoning  String?           @db.Text

  @@unique([trialId, dimension])
  @@index([trialId])
  @@map("trial_scores")
}

// TrialLegal — WPTA agreement record (one per trial).
model TrialLegal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  trialId String @unique
  trial   Trial  @relation(fields: [trialId], references: [id], onDelete: Cascade)

  wptaDocumentCid   String? // IPFS CID of the generated agreement PDF
  jurisdiction      String  @default("US")
  employerSignature String?
  employerSignedAt  DateTime?
  candidateSignature String?
  candidateSignedAt  DateTime?
  docusignEnvelopeId String?

  @@map("trial_legal")
}

// ─── Phase 10: RoleFit AI ─────────────────────────────────────────────────────

enum RoleDomain {
  CODE
  DESIGN
  WRITING
  DATA
  MANAGEMENT
  SALES
}

enum RoleExtractionStatus {
  PENDING
  EXTRACTING
  DONE
  FAILED
}

// Role — employer-defined position; requirement extraction produces capability vector.
model Role {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employerId String
  title      String
  descriptionText String? @db.Text

  domain             RoleDomain @default(CODE)
  compensationMinUsd Int?
  compensationMaxUsd Int?
  remote             Boolean @default(true)
  location           String?

  // Requirement extraction sources
  githubRepoUrl   String?
  figmaProjectUrl String?

  // Extracted by Python AI service (GitHub + Tree-sitter analysis)
  extractedRequirements Json?
  // 2048-dim capability vector (stored for dev-mode cosine similarity; prod uses Pinecone)
  capabilityVector      Json?
  pineconeVectorId      String?
  extractionStatus      RoleExtractionStatus @default(PENDING)

  blindMode Boolean @default(true)
  active    Boolean @default(true)

  fitScores    StoredFitScore[]
  hireOutcomes HireOutcome[]
  referrals    Referral[]
  bounty       BountyListing?

  @@index([employerId])
  @@index([active])
  @@map("roles")
}

// StoredFitScore — cached match result between a role and a candidate.
// 5 dimensions: Capability 35%, Culture 20%, Growth 20%, Comp 15%, Career 10%
model StoredFitScore {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  roleId      String
  role        Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   User   @relation("CandidateFitScores", fields: [candidateId], references: [id], onDelete: Cascade)

  overallScore    Int
  capabilityScore Int
  cultureScore    Int
  growthScore     Int
  compScore       Int
  careerScore     Int

  // SHAP-style explainability: top factors + per-dimension breakdown
  explainability Json

  blindMode         Boolean @default(true)
  employerInterest  Boolean @default(false)
  candidateInterest Boolean @default(false)
  revealedAt        DateTime?

  hireOutcome HireOutcome?

  @@unique([roleId, candidateId])
  @@index([roleId])
  @@index([candidateId])
  @@index([overallScore(sort: Desc)])
  @@map("stored_fit_scores")
}

// HireOutcome — recorded after hire decision; feeds PPO RL model retraining.
model HireOutcome {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  roleId      String
  role        Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  candidateId String

  hired                Boolean
  daysToHire           Int?
  performanceRating90d Decimal? @db.Decimal(3, 2) // 1.0–5.0
  tenureMonths         Int?

  fitScoreId String?          @unique
  fitScore   StoredFitScore?  @relation(fields: [fitScoreId], references: [id], onDelete: SetNull)

  @@index([roleId])
  @@map("hire_outcomes")
}

// ─── Phase 11: TrustChain Talent ─────────────────────────────────────────────

// TrustEdge — directed weighted edge in the AI trust graph.
// Built from verified co-employment histories. GraphSAGE runs over this table.
model TrustEdge {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  fromUserId String
  from       User   @relation("TrustEdgeFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  to         User   @relation("TrustEdgeTo", fields: [toUserId], references: [id], onDelete: Cascade)

  strengthScore       Decimal @db.Decimal(4, 3) @default(0.5)
  coEmploymentMonths  Int     @default(0)
  sourceType          String  @default("co_employment") // co_employment | endorsement | referral_success
  evidenceTxHash      String?

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("trust_edges")
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  HIRED
  TRANCHE1_RELEASED
  TRANCHE2_RELEASED
  TRANCHE3_RELEASED
  COMPLETED
  REJECTED
  EXPIRED
}

enum BountyStatus {
  OPEN
  FILLED
  CANCELLED
  EXPIRED
}

// Referral — one referral from a TrustChain member to a candidate for a role.
// Smart contract (ReferralEscrow.sol) holds bounty; releases in 3 tranches.
model Referral {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referrerId  String
  referrer    User   @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   User   @relation("CandidateReferrals", fields: [candidateId], references: [id], onDelete: Cascade)
  roleId      String
  role        Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  note   String? @db.Text
  status ReferralStatus @default(PENDING)

  // On-chain escrow
  contractAddress String?
  bountyTotalUsd  Int?

  // Tranche timestamps + tx hashes
  tranche1PaidAt DateTime?
  tranche2PaidAt DateTime?
  tranche3PaidAt DateTime?
  hireTimestamp  DateTime?
  txHashTranche1 String?
  txHashTranche2 String?
  txHashTranche3 String?

  // Anti-collusion score (Isolation Forest output, 0 = clean, 1 = suspicious)
  antiCollusionScore Decimal? @db.Decimal(4, 3)

  @@index([referrerId])
  @@index([candidateId])
  @@index([roleId])
  @@index([status])
  @@map("referrals")
}

// BountyListing — employer-posted open bounty for a role.
model BountyListing {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employerId    String
  roleId        String  @unique
  role          Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  totalBountyUsd Int
  domain        String @default("CODE")
  status        BountyStatus @default(OPEN)
  contractAddress String?
  expiresAt     DateTime?

  @@index([status])
  @@map("bounty_listings")
}

// ─────────────────────────────────────────────────────────────
// Phase 12 — University Issuers + OpenRep Issuer Registry
// ─────────────────────────────────────────────────────────────

enum IssuerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum IssuedCredentialType {
  DEGREE
  CERTIFICATION
  TRANSCRIPT
  PROFESSIONAL_LICENSE
}

// University or institution registered as an OpenRep issuer.
// First 10 university issuers onboarded in Phase 12.
model UniversityIssuer {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  did         String @unique // did:polygon:0x… — issuer's on-chain identity
  name        String
  domain      String @unique // e.g. "mit.edu"
  countryCode String // ISO 3166-1 alpha-2
  logoUrl     String?
  websiteUrl  String?

  // Hashed API key for credential issuance (never stored plaintext)
  issuerApiKeyHash String @unique

  status     IssuerStatus @default(PENDING)
  verifiedAt DateTime?

  credentials IssuedCredential[]

  @@map("university_issuers")
}

// Credential issued by a university to a professional (non-PII metadata only).
// Evidence stored on IPFS; chain hash anchored on Polygon.
model IssuedCredential {
  id        String   @id @default(cuid())
  issuedAt  DateTime @default(now())

  issuerId       String
  issuer         UniversityIssuer @relation(fields: [issuerId], references: [id], onDelete: Cascade)

  profileDid     String // recipient DID
  credentialType IssuedCredentialType
  schemaUrl      String  // W3C VC schema URL
  evidenceCid    String? // IPFS CID of evidence (no PII on Polygon)
  chainTxHash    String?
  expiresAt      DateTime?
  revokedAt      DateTime?

  @@index([issuerId])
  @@index([profileDid])
  @@map("issued_credentials")
}

// Government integration stubs (Phase 12 — India DPDP, USPTO, State Bar).
model GovIntegration {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  type         String // INDIA_DPDP | USPTO | STATE_BAR
  jurisdiction String // e.g. "IN", "US", "US-CA"
  apiEndpoint  String?
  status       String @default("PENDING")
  lastSyncAt   DateTime?

  @@map("gov_integrations")
}
